{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(node scripts/ai-audit/cli.mjs *)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status *)",
      "Bash(git -C * branch *)",
      "Bash(git -C * show *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * worktree *)",
      "Bash(python3 - *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start-context.sh",
            "timeout": 30,
            "statusMessage": "Loading session context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-context.sh",
            "timeout": 15,
            "statusMessage": "Checking pre-commit context..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-commit-message.sh",
            "timeout": 10,
            "statusMessage": "Checking commit message format..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-code-review.sh",
            "timeout": 10,
            "statusMessage": "Checking code-review gate..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-static-analysis.sh",
            "timeout": 180,
            "statusMessage": "Running Checkstyle + PMD..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-settings-bash.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/persona-inject.sh",
            "timeout": 10,
            "statusMessage": "Loading persona context..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-settings.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/persona-inject.sh",
            "timeout": 10,
            "statusMessage": "Loading persona context..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-settings.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-skill-prereqs.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/post-tool-use-memory.js",
            "timeout": 30,
            "statusMessage": "Updating memory..."
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-feat-html.js",
            "timeout": 15,
            "statusMessage": "Validating feat HTML..."
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-feat-index.js",
            "timeout": 15,
            "statusMessage": "Validating feat index..."
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/copy-permissions-to-worktree.js",
            "timeout": 10,
            "statusMessage": "Copying settings to new worktree..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-stop-report.sh",
            "timeout": 10,
            "statusMessage": "Generating session report..."
          }
        ]
      }
    ]
  }
}
