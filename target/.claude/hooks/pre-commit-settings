#!/usr/bin/env bash
# Git pre-commit hook — settings.json 변경 검증
# 설치: ln -sf ../../.claude/hooks/pre-commit-settings .git/hooks/pre-commit-settings

# Lefthook에서 자동 호출하거나, .git/hooks/pre-commit에서 수동 호출

CHANGED=$(git diff --cached --name-only | grep -E '\.claude/(settings\.json|hooks/guard-.*\.sh)$')

if [ -z "$CHANGED" ]; then
    exit 0
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🔒 Settings Protection Gate"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  다음 파일의 변경이 감지되었습니다:"
echo "$CHANGED" | sed 's/^/    - /'
echo ""
echo "  ⚠️  Hook 설정 변경은 신중해야 합니다"
echo ""
echo "  계속하려면:"
echo "  1. 변경 사항을 팀원과 공유"
echo "  2. 코드 리뷰 승인 획득"
echo "  3. SETTINGS_COMMIT=1 git commit"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ "$SETTINGS_COMMIT" != "1" ]; then
    exit 1
fi

echo "  ✅ SETTINGS_COMMIT=1 감지 — 커밋 허용"
echo ""
exit 0
